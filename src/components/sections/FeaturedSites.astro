---
const sites = [
  {
    name: 'Snaildev',
    url: 'https://snaildev.uk',
    description: 'Development & creative studio',
  },
  {
    name: 'ImaHappy',
    url: 'https://imahappy.eu',
    description: 'Community platform',
  },
];
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Sites We Host</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Real websites running on our infrastructure. Fast, reliable, and always online.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
      {sites.map(site => (
        <a
          href={site.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block p-6 bg-gray-50 border border-gray-100 rounded-2xl hover:border-brand-blue hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
        >
          <div class="flex items-center justify-between mb-3">
            <div class="w-10 h-10 bg-brand-gradient rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            </div>
            <svg class="w-4 h-4 text-gray-400 group-hover:text-brand-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 group-hover:text-brand-blue transition-colors">{site.name}</h3>
          <p class="text-sm text-gray-500 mt-1">{site.description}</p>
          <p class="text-xs text-gray-400 mt-2">{site.url.replace('https://', '')}</p>
        </a>
      ))}
    </div>
    <p class="text-center text-sm text-gray-500 mt-8">
      Want your site listed here?{' '}
      <a href="/contact" class="text-brand-blue hover:underline font-medium">Get in touch →</a>
    </p>
  </div>
</section>
