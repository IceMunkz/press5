---
import Layout from '../components/layout/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import PricingTable from '../components/sections/PricingTable';
import Accordion from '../components/ui/Accordion';

const bots = [
  {
    name: 'MEE6',
    servers: '21M+ servers',
    color: '#FF0000',
    bg: 'bg-red-50',
    border: 'border-red-100',
    badge: 'bg-red-100 text-red-700',
    description: 'The most widely-used Discord bot on the planet. MEE6 handles moderation, leveling, welcome messages, reaction roles, and custom commands — all in one.',
    features: [
      'Auto-moderation (anti-spam, banned words, invite links)',
      'Leveling & XP with role rewards and leaderboards',
      'Custom commands and auto-responders',
      'Welcome & leave messages with embeds',
      'Reaction roles and button roles',
      'Scheduled announcements',
    ],
    icon: '🔴',
  },
  {
    name: 'Carl-bot',
    servers: '9M+ servers',
    color: '#FF4500',
    bg: 'bg-orange-50',
    border: 'border-orange-100',
    badge: 'bg-orange-100 text-orange-700',
    description: 'The go-to bot for reaction roles and advanced moderation logging. Carl-bot is trusted by communities that need fine-grained control over their server.',
    features: [
      'Reaction roles, button roles, and select menus',
      'Comprehensive moderation logging',
      'Advanced automod with per-channel rules',
      'Custom tags and commands',
      'Reddit, YouTube, and Twitch feeds',
      'Welcome messages and role-gates',
    ],
    icon: '🟠',
  },
  {
    name: 'ProBot',
    servers: '9M+ servers',
    color: '#F59E0B',
    bg: 'bg-yellow-50',
    border: 'border-yellow-100',
    badge: 'bg-yellow-100 text-yellow-700',
    description: 'ProBot is known for its beautiful welcome card images and powerful anti-raid tools — ideal for growing communities that want a polished first impression.',
    features: [
      'Stunning image welcome cards (fully customisable)',
      'Anti-raid protection and mass-join detection',
      'Auto-moderation with warning system',
      'Server stats and member counters',
      'Embed builder for announcements',
      'Temporary channels and voice management',
    ],
    icon: '🟡',
  },
  {
    name: 'Dyno',
    servers: '800K+ trusted servers',
    color: '#10B981',
    bg: 'bg-green-50',
    border: 'border-green-100',
    badge: 'bg-green-100 text-green-700',
    description: 'One of the most stable and battle-tested moderation bots available. Dyno has been trusted by large communities for years and never lets them down.',
    features: [
      'Advanced moderation (ban, mute, tempban, deafen)',
      'Auto-roles on join and role management',
      'Custom commands and auto-responders',
      'Scheduled announcements and reminders',
      'Anti-spam and anti-raid tools',
      'Full audit log and moderation history',
    ],
    icon: '🟢',
  },
  {
    name: 'Dank Memer',
    servers: '8.6M+ servers',
    color: '#EC4899',
    bg: 'bg-pink-50',
    border: 'border-pink-100',
    badge: 'bg-pink-100 text-pink-700',
    description: 'The most popular fun and economy bot on Discord. Dank Memer brings your community together with a full currency system, memes, mini-games, and more.',
    features: [
      'Full economy system (coins, shop, trading)',
      'Work, crime, heist, and gambling commands',
      'Meme and image generation commands',
      'Mini-games and trivia',
      'Community events and giveaways',
      'Pet system and collectibles',
    ],
    icon: '🩷',
  },
];

const tiers = [
  {
    name: 'Essential',
    monthlyPrice: 3.99,
    annualPrice: 3.32,
    description: 'The two most important bots for any Discord server.',
    features: [
      'MEE6 + Carl-bot hosted for you',
      'Shared bot instances',
      '1 Discord server',
      '99.9% uptime SLA',
      'Configuration assistance',
      'Email support',
    ],
    ctaLabel: 'Get Started',
    ctaHref: '/contact?service=discord-bots',
  },
  {
    name: 'All Five',
    monthlyPrice: 7.99,
    annualPrice: 6.66,
    description: 'All 5 top bots running for your community.',
    features: [
      'All 5 bots (MEE6, Carl-bot, ProBot, Dyno, Dank Memer)',
      'Shared bot instances',
      'Up to 3 Discord servers',
      '99.9% uptime SLA',
      'Full configuration assistance',
      'Priority email support',
    ],
    popular: true,
    ctaLabel: 'Get All Five',
    ctaHref: '/contact?service=discord-bots',
  },
  {
    name: 'Dedicated',
    monthlyPrice: 14.99,
    annualPrice: 12.49,
    description: 'Dedicated instances for high-traffic servers that need peak performance.',
    features: [
      'All 5 bots on dedicated resources',
      'No shared load — your bots only',
      'Unlimited Discord servers',
      '99.9% uptime SLA',
      'Full setup and custom configuration',
      'Priority support with faster response',
      'Early access to newly added bots',
    ],
    ctaLabel: 'Get Dedicated',
    ctaHref: '/contact?service=discord-bots',
  },
];

const faqs = [
  {
    question: 'Why these 5 bots specifically?',
    answer: 'MEE6, Carl-bot, ProBot, Dyno, and Dank Memer are consistently the most-used Discord bots in the world by server count. Together they cover every core community need: moderation, roles, welcome messages, economy, and fun. Rather than maintaining a sprawling library of 20 mediocre bots, we focus on these 5 and host them properly.',
  },
  {
    question: 'How do I add a bot to my server?',
    answer: 'After subscribing, we send you invite links for each bot. You authorise them on your server through the standard Discord OAuth flow — same as any other bot. Takes about 2 minutes per bot.',
  },
  {
    question: 'Do I still get to configure the bots how I want?',
    answer: 'Absolutely. You get full access to configure each bot — custom prefixes, command permissions, automod rules, leveling settings, economy configuration. We just handle the hosting and uptime so you never have to think about the server side.',
  },
  {
    question: 'What if a bot goes offline?',
    answer: 'We monitor all bots 24/7 and restart them automatically within seconds of any crash. You can check live bot status on our status page. If there\'s a wider issue, we post updates there.',
  },
  {
    question: 'Can I use these bots on multiple servers?',
    answer: 'Essential covers 1 server. All Five covers up to 3. Dedicated is unlimited across as many servers as you need.',
  },
  {
    question: 'Are these the actual MEE6/Carl-bot/Dyno bots or your own versions?',
    answer: 'We self-host our own instances of these open-source or self-hostable bots. This means we control uptime, updates, and configuration — no dependency on a third-party service going down. Your data stays on our infrastructure.',
  },
  {
    question: 'Do the bots have ads or usage limits?',
    answer: 'No ads, no artificial rate limits, and no paywalled commands. The free tiers of MEE6/Dyno etc. lock features behind subscriptions — our hosted versions give you full functionality on every plan.',
  },
  {
    question: 'What\'s the difference between shared and dedicated?',
    answer: 'On shared plans your bots run alongside other subscribers\' bots on the same process. On Dedicated, your bots have their own resources — faster response times and no slowdown during peak hours elsewhere.',
  },
];
---

<Layout
  title="Managed Discord Bots"
  description="We host and maintain the world's 5 most popular Discord bots — MEE6, Carl-bot, ProBot, Dyno, and Dank Memer. No setup, no crashes. From £3.99/month."
>
  <Hero
    gradient="linear-gradient(135deg, #5865F2 0%, #7C3AED 100%)"
    title="The World's Top 5 Discord Bots. Hosted for You."
    subtitle="MEE6. Carl-bot. ProBot. Dyno. Dank Memer. The 5 most popular Discord bots in the world — running on our infrastructure so you never have to touch a server."
  >
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#bots"
        class="inline-flex items-center gap-2 px-8 py-4 bg-white text-indigo-600 font-bold rounded-xl hover:bg-indigo-50 transition-colors shadow-lg"
      >
        Meet the 5 Bots
      </a>
      <a
        href="#pricing"
        class="inline-flex items-center gap-2 px-8 py-4 border-2 border-white/40 text-white font-bold rounded-xl hover:bg-white/10 transition-colors"
      >
        View Plans
      </a>
    </div>
  </Hero>

  <TrustBar />

  <!-- Why managed -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-red-50 text-red-700 rounded-full text-sm font-semibold mb-4">
            😤 The Problem with Self-Hosting Bots
          </div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Running these bots yourself is more work than it looks</h2>
          <ul class="space-y-3">
            {[
              'Bots go offline and you have to restart them manually',
              'Updates break things — you\'re the one who has to fix it',
              'MEE6/Dyno free tiers lock the best features behind subscriptions',
              'Need a VPS running 24/7 just to keep them alive',
              'Debugging crashes at 3am because the bot is down',
            ].map(p => (
              <li class="flex items-start gap-3 text-gray-600">
                <span class="text-red-400 flex-shrink-0 mt-0.5 font-bold">✗</span>
                {p}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-green-50 text-green-700 rounded-full text-sm font-semibold mb-4">
            ✅ The Press5 Way
          </div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">We run them. You just use them.</h2>
          <ul class="space-y-3">
            {[
              'All 5 bots monitored and auto-restarted 24/7',
              'We handle every update, patch, and security fix',
              'Full features unlocked — no artificial free-tier limits',
              'Invite any bot to your server in under 2 minutes',
              'One subscription covers everything',
            ].map(p => (
              <li class="flex items-start gap-3 text-gray-600">
                <span class="text-green-500 flex-shrink-0 mt-0.5 font-bold">✓</span>
                {p}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- The 5 bots -->
  <section id="bots" class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">The 5 Bots Every Discord Community Needs</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Chosen because they're the most battle-tested, most-used, and most-loved bots in the Discord ecosystem. Together they cover everything.
        </p>
      </div>
      <div class="space-y-6">
        {bots.map((bot, i) => (
          <div class={`rounded-2xl border p-6 sm:p-8 ${bot.bg} ${bot.border}`}>
            <div class="flex flex-col sm:flex-row sm:items-start gap-6">
              <div class="flex-shrink-0">
                <div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center text-3xl shadow-sm border border-white/50">
                  {bot.icon}
                </div>
              </div>
              <div class="flex-1">
                <div class="flex flex-wrap items-center gap-3 mb-2">
                  <h3 class="text-2xl font-bold text-gray-900">{bot.name}</h3>
                  <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${bot.badge}`}>
                    {bot.servers}
                  </span>
                </div>
                <p class="text-gray-600 mb-4 leading-relaxed">{bot.description}</p>
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1.5">
                  {bot.features.map(f => (
                    <li class="flex items-center gap-2 text-sm text-gray-700">
                      <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      {f}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lavalink callout -->
  <section class="py-12 bg-white border-y border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl p-8 flex flex-col sm:flex-row items-center gap-6 text-white" style="background: linear-gradient(135deg, #7C3AED 0%, #DB2777 100%)">
        <div class="text-5xl">🎵</div>
        <div class="flex-1">
          <h3 class="text-xl font-bold mb-1">Need a Lavalink server for your own music bot?</h3>
          <p class="text-purple-100 text-sm">If you run your own Discord music bot and need a Lavalink audio backend, we host those too. UK-based, low latency, Spotify support.</p>
        </div>
        <a
          href="/lavalink"
          class="flex-shrink-0 px-6 py-3 bg-white text-purple-700 font-bold rounded-xl hover:bg-purple-50 transition-colors whitespace-nowrap"
        >
          View Lavalink Plans →
        </a>
      </div>
    </div>
  </section>

  <div id="pricing">
    <PricingTable
      client:load
      tiers={tiers}
      title="Simple, Honest Pricing"
      subtitle="One subscription. All bots fully unlocked. No per-bot fees, no artificial free-tier limits."
    />
  </div>

  <Accordion
    client:load
    title="Frequently Asked Questions"
    items={faqs}
  />

  <CTABanner
    title="5 bots. One subscription. Zero maintenance."
    subtitle="The world's most popular Discord bots, running on our infrastructure. You just invite and configure."
    primaryHref="/contact?service=discord-bots"
    primaryLabel="Get Started"
    secondaryHref="#pricing"
    secondaryLabel="Compare Plans"
  />
</Layout>
