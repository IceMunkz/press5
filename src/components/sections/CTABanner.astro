---
interface Props {
  title?: string;
  subtitle?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  title = 'Ready to get started?',
  subtitle = 'Plans start from just £3/month. No contracts, cancel any time.',
  primaryHref = '/contact',
  primaryLabel = 'Get Started Today',
  secondaryHref = '/web-hosting',
  secondaryLabel = 'View Plans',
} = Astro.props;
---

<section class="bg-gray-950 py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">{title}</h2>
    <p class="text-lg text-gray-400 mb-8 max-w-xl mx-auto">{subtitle}</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={primaryHref}
        class="inline-flex items-center gap-2 px-8 py-3 bg-brand-gradient text-white font-semibold rounded-xl hover:opacity-90 transition-opacity shadow-lg shadow-blue-900/30"
      >
        {primaryLabel}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href={secondaryHref}
        class="inline-flex items-center gap-2 px-8 py-3 border border-gray-700 text-gray-300 font-semibold rounded-xl hover:border-gray-500 hover:text-white transition-colors"
      >
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>
