---
const sites = [
  {
    name: 'Snaildev',
    url: 'https://snaildev.uk',
    description: 'Development & creative studio',
    category: 'Web Dev',
  },
  {
    name: 'ImaHappy',
    url: 'https://imahappy.eu',
    description: 'Community platform',
    category: 'Community',
  },
  {
    name: 'RScrims',
    url: 'https://rscrims.com',
    description: 'Rust scrimmage & competitive gaming community',
    category: 'Gaming',
  },
];

function thumbUrl(siteUrl: string) {
  // thum.io is a free, no-signup screenshot service
  return `https://image.thum.io/get/width/800/crop/500/noanimate/${siteUrl}`;
}
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-blue-50 text-brand-blue rounded-full text-sm font-semibold mb-4">
        🌐 Live Examples
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Sites We Host</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Real websites running on our infrastructure. Fast, reliable, and always online.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {sites.map(site => (
        <a
          href={site.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-white border border-gray-100 rounded-2xl overflow-hidden hover:border-brand-blue hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
        >
          <!-- Screenshot thumbnail -->
          <div class="relative overflow-hidden bg-gray-100 h-48">
            <img
              src={thumbUrl(site.url)}
              alt={`Screenshot of ${site.name}`}
              class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              onerror="this.parentElement.classList.add('flex','items-center','justify-center'); this.style.display='none'; this.parentElement.innerHTML += '<div class=\'text-gray-400 text-5xl\'>🌐</div>'"
            />
            <!-- Overlay on hover -->
            <div class="absolute inset-0 bg-brand-blue/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <span class="bg-white text-brand-blue text-sm font-semibold px-4 py-2 rounded-full shadow-lg flex items-center gap-2">
                Visit Site
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </span>
            </div>
          </div>

          <!-- Card content -->
          <div class="p-5">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-bold text-gray-900 group-hover:text-brand-blue transition-colors">{site.name}</h3>
              <span class="text-xs px-2 py-0.5 bg-blue-50 text-brand-blue rounded-full font-medium">{site.category}</span>
            </div>
            <p class="text-sm text-gray-500 mb-3">{site.description}</p>
            <p class="text-xs text-gray-400 flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
              {site.url.replace('https://', '')}
            </p>
          </div>
        </a>
      ))}
    </div>

    <p class="text-center text-sm text-gray-500 mt-10">
      Want your site listed here?{' '}
      <a href="/contact" class="text-brand-blue hover:underline font-medium">Get in touch →</a>
    </p>
  </div>
</section>
