---
import Layout from '../components/layout/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import PricingTable from '../components/sections/PricingTable';
import Accordion from '../components/ui/Accordion';

const communityBots = [
  {
    name: 'MEE6',
    servers: '21M+ servers',
    bg: 'bg-red-50',
    border: 'border-red-100',
    badge: 'bg-red-100 text-red-700',
    description: 'The most widely-used Discord bot on the planet. Moderation, leveling, welcome messages, reaction roles, and custom commands — all in one.',
    features: [
      'Auto-moderation (anti-spam, banned words, invite links)',
      'Leveling & XP with role rewards and leaderboards',
      'Custom commands and auto-responders',
      'Welcome & leave messages with embeds',
      'Reaction roles and button roles',
      'Scheduled announcements',
    ],
    icon: '🔴',
    lavalink: false,
  },
  {
    name: 'Carl-bot',
    servers: '9M+ servers',
    bg: 'bg-orange-50',
    border: 'border-orange-100',
    badge: 'bg-orange-100 text-orange-700',
    description: 'The go-to bot for reaction roles and advanced moderation logging. Trusted by communities that need fine-grained control over their server.',
    features: [
      'Reaction roles, button roles, and select menus',
      'Comprehensive moderation logging',
      'Advanced automod with per-channel rules',
      'Custom tags and commands',
      'Reddit, YouTube, and Twitch feeds',
      'Welcome messages and role-gates',
    ],
    icon: '🟠',
    lavalink: false,
  },
  {
    name: 'ProBot',
    servers: '9M+ servers',
    bg: 'bg-yellow-50',
    border: 'border-yellow-100',
    badge: 'bg-yellow-100 text-yellow-700',
    description: 'Known for stunning welcome image cards and powerful anti-raid tools — ideal for growing communities that want a polished first impression.',
    features: [
      'Stunning image welcome cards (fully customisable)',
      'Anti-raid protection and mass-join detection',
      'Auto-moderation with warning system',
      'Server stats and member counters',
      'Embed builder for announcements',
      'Temporary channels and voice management',
    ],
    icon: '🟡',
    lavalink: false,
  },
  {
    name: 'Dyno',
    servers: '800K+ trusted servers',
    bg: 'bg-green-50',
    border: 'border-green-100',
    badge: 'bg-green-100 text-green-700',
    description: 'One of the most stable and battle-tested moderation bots available. Dyno has been trusted by large communities for years and never lets them down.',
    features: [
      'Advanced moderation (ban, mute, tempban, deafen)',
      'Auto-roles on join and role management',
      'Custom commands and auto-responders',
      'Scheduled announcements and reminders',
      'Anti-spam and anti-raid tools',
      'Full audit log and moderation history',
    ],
    icon: '🟢',
    lavalink: false,
  },
  {
    name: 'Dank Memer',
    servers: '8.6M+ servers',
    bg: 'bg-pink-50',
    border: 'border-pink-100',
    badge: 'bg-pink-100 text-pink-700',
    description: 'The most popular fun and economy bot on Discord. Brings your community together with a full currency system, memes, mini-games, and more.',
    features: [
      'Full economy system (coins, shop, trading)',
      'Work, crime, heist, and gambling commands',
      'Meme and image generation commands',
      'Mini-games and trivia',
      'Community events and giveaways',
      'Pet system and collectibles',
    ],
    icon: '🩷',
    lavalink: false,
  },
];

const musicBots = [
  {
    name: 'Hydra',
    servers: '#1 rated music bot 2025',
    bg: 'bg-blue-50',
    border: 'border-blue-100',
    badge: 'bg-blue-100 text-blue-700',
    description: 'The most consistently top-ranked music bot in 2025. Hydra is known for its stability, platform support, and a premium dashboard that gives full control over playback.',
    features: [
      'YouTube, Spotify, SoundCloud streaming',
      'Queue management with skip voting',
      'Audio filters and equaliser',
      'Premium dashboard for full server control',
      '24/7 playback mode',
      'Playlist saving and sharing',
    ],
    icon: '💧',
    lavalink: false,
  },
  {
    name: 'Jockie Music',
    servers: 'Multi-instance music bot',
    bg: 'bg-indigo-50',
    border: 'border-indigo-100',
    badge: 'bg-indigo-100 text-indigo-700',
    description: 'Unique in that it supports multiple simultaneous instances — different queues playing in different voice channels at the same time. Widest platform support of any music bot.',
    features: [
      'Up to 4 simultaneous instances per server',
      'Spotify, Apple Music, YouTube, Deezer, TIDAL, SoundCloud',
      'Separate queues per voice channel',
      'Slash command support',
      'Queue looping and shuffle',
      'Lyrics display',
    ],
    icon: '🎶',
    lavalink: false,
  },
  {
    name: 'FredBoat',
    servers: 'Open-source & battle-tested',
    bg: 'bg-cyan-50',
    border: 'border-cyan-100',
    badge: 'bg-cyan-100 text-cyan-700',
    description: 'One of the oldest and most trusted open-source music bots. FredBoat has been running reliably for years and is powered by Lavalink under the hood.',
    features: [
      'YouTube, Spotify, SoundCloud, Bandcamp',
      'Playlist import from YouTube and Spotify',
      'Queue management and history',
      'Auto-play from recommendations',
      'Volume and audio controls',
      'Powered by Lavalink for high-quality audio',
    ],
    icon: '⛵',
    lavalink: true,
  },
  {
    name: 'Uzox',
    servers: '500K+ servers',
    bg: 'bg-violet-50',
    border: 'border-violet-100',
    badge: 'bg-violet-100 text-violet-700',
    description: 'Built from the ground up around Lavalink. Uzox is designed for audio quality first — it requires a Lavalink server to run, making it one of the best-sounding bots available.',
    features: [
      'Lavalink-native architecture',
      'YouTube, Spotify, SoundCloud support',
      'High-quality, lag-free audio',
      'Interactive now-playing controls',
      'Queue with pagination',
      'Audio filters and bass boost',
    ],
    icon: '🔊',
    lavalink: true,
  },
];

const tiers = [
  {
    name: 'Community',
    monthlyPrice: 7.99,
    annualPrice: 6.66,
    description: 'All 5 community & moderation bots for your server.',
    features: [
      'MEE6, Carl-bot, ProBot, Dyno & Dank Memer',
      'Shared bot instances',
      'Up to 2 Discord servers',
      '99.9% uptime SLA',
      'Configuration assistance',
      'Email support',
    ],
    ctaLabel: 'Get Community',
    ctaHref: '/contact?service=discord-bots&tier=community',
  },
  {
    name: 'Full Bundle',
    monthlyPrice: 14.99,
    annualPrice: 12.49,
    description: 'All 9 bots — community, moderation, and music.',
    features: [
      'All 5 community bots',
      'All 4 music bots (incl. Lavalink-powered)',
      'Shared bot instances',
      'Up to 5 Discord servers',
      '99.9% uptime SLA',
      'Full configuration assistance',
      'Priority email support',
    ],
    popular: true,
    ctaLabel: 'Get Full Bundle',
    ctaHref: '/contact?service=discord-bots&tier=bundle',
  },
  {
    name: 'Dedicated',
    monthlyPrice: 24.99,
    annualPrice: 20.82,
    description: 'All 9 bots on dedicated resources for high-traffic servers.',
    features: [
      'All 9 bots on dedicated instances',
      'No shared load — your bots only',
      'Unlimited Discord servers',
      '99.9% uptime SLA',
      'Full setup and custom configuration',
      'Priority support with faster response',
      'Early access to newly added bots',
    ],
    ctaLabel: 'Get Dedicated',
    ctaHref: '/contact?service=discord-bots&tier=dedicated',
  },
];

const faqs = [
  {
    question: 'Why these 9 bots specifically?',
    answer: 'The 5 community bots (MEE6, Carl-bot, ProBot, Dyno, Dank Memer) are the most-used Discord bots in the world by server count and cover every moderation and community need. The 4 music bots (Hydra, Jockie Music, FredBoat, Uzox) are the most reliable and feature-rich music options available — two of which (FredBoat and Uzox) are powered by Lavalink for the best possible audio quality.',
  },
  {
    question: 'What\'s special about the Lavalink-powered music bots?',
    answer: 'FredBoat and Uzox use Lavalink as their audio backend — a dedicated Java audio server that handles all the streaming and encoding separately from the bot process. This means dramatically better audio quality, lower latency, and no performance impact on the bot itself. We run our own UK-based Lavalink nodes so these bots perform at their best.',
  },
  {
    question: 'Do I need a separate Lavalink plan for the music bots?',
    answer: 'No — the Lavalink infrastructure is included in your bot hosting plan when you choose FredBoat or Uzox. If you want to connect your own custom bot to our Lavalink nodes separately, check out our dedicated Lavalink hosting plans.',
  },
  {
    question: 'How do I add a bot to my server?',
    answer: 'After subscribing we send you invite links for each bot. You authorise them on your server through Discord\'s standard OAuth flow — same as any other bot. Takes about 2 minutes per bot.',
  },
  {
    question: 'Can I configure each bot myself?',
    answer: 'Absolutely. You get full control to configure each bot — command prefixes, permissions, automod rules, leveling settings, music queue limits, economy settings. We handle the hosting and uptime, you handle the configuration.',
  },
  {
    question: 'What if a bot goes offline?',
    answer: 'We monitor all 9 bots 24/7 and restart them automatically within seconds of any crash. You can check live status on our status page.',
  },
  {
    question: 'Can I use the bots on multiple servers?',
    answer: 'Community covers up to 2 servers. Full Bundle covers up to 5. Dedicated is unlimited. Just let us know your servers when you sign up.',
  },
  {
    question: 'Are these the actual bots or your own versions?',
    answer: 'We self-host our own instances of these open-source bots. This means we control uptime, updates, and configuration — no dependency on a third-party service going down. Full features unlocked on every plan, no artificial free-tier limits.',
  },
  {
    question: 'Can Jockie Music really play in multiple channels at once?',
    answer: 'Yes — Jockie Music supports multiple simultaneous instances, so different voice channels on your server can each have their own independent queue playing at the same time. Great for large servers with different communities in different channels.',
  },
];
---

<Layout
  title="Managed Discord Bots"
  description="We host and maintain 9 of the world's best Discord bots — MEE6, Carl-bot, ProBot, Dyno, Dank Memer, Hydra, Jockie Music, FredBoat, and Uzox. From £7.99/month."
>
  <Hero
    gradient="linear-gradient(135deg, #5865F2 0%, #7C3AED 100%)"
    title="9 of the World's Best Discord Bots. Hosted for You."
    subtitle="5 community & moderation bots. 4 music bots — including two powered by Lavalink. All running on our infrastructure so you never have to touch a server."
  >
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#bots"
        class="inline-flex items-center gap-2 px-8 py-4 bg-white text-indigo-600 font-bold rounded-xl hover:bg-indigo-50 transition-colors shadow-lg"
      >
        See All 9 Bots
      </a>
      <a
        href="#pricing"
        class="inline-flex items-center gap-2 px-8 py-4 border-2 border-white/40 text-white font-bold rounded-xl hover:bg-white/10 transition-colors"
      >
        View Plans
      </a>
    </div>
  </Hero>

  <TrustBar />

  <!-- Why managed -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-red-50 text-red-700 rounded-full text-sm font-semibold mb-4">
            😤 The Problem with Self-Hosting Bots
          </div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Running these bots yourself is more work than it looks</h2>
          <ul class="space-y-3">
            {[
              'Bots go offline and you have to restart them manually',
              'Updates break things — you\'re the one who has to fix it',
              'MEE6/Dyno free tiers lock the best features behind subscriptions',
              'Lavalink music bots need a separate audio server to even function',
              'Debugging crashes at 3am because the bot is down',
            ].map(p => (
              <li class="flex items-start gap-3 text-gray-600">
                <span class="text-red-400 flex-shrink-0 mt-0.5 font-bold">✗</span>
                {p}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-green-50 text-green-700 rounded-full text-sm font-semibold mb-4">
            ✅ The Press5 Way
          </div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">We run them. You just use them.</h2>
          <ul class="space-y-3">
            {[
              'All 9 bots monitored and auto-restarted 24/7',
              'We handle every update, patch, and security fix',
              'Full features unlocked — no artificial free-tier limits',
              'Lavalink infrastructure included for music bots',
              'One subscription covers everything',
            ].map(p => (
              <li class="flex items-start gap-3 text-gray-600">
                <span class="text-green-500 flex-shrink-0 mt-0.5 font-bold">✓</span>
                {p}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Bot sections -->
  <section id="bots" class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Community bots -->
      <div class="mb-16">
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-blue-50 text-brand-blue rounded-full text-sm font-semibold mb-4">
            🛡️ Community & Moderation
          </div>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3">The 5 bots every server needs</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">The most-used Discord bots in the world, covering moderation, roles, leveling, economy, and fun.</p>
        </div>
        <div class="space-y-4">
          {communityBots.map(bot => (
            <div class={`rounded-2xl border p-6 sm:p-8 ${bot.bg} ${bot.border}`}>
              <div class="flex flex-col sm:flex-row sm:items-start gap-6">
                <div class="flex-shrink-0">
                  <div class="w-14 h-14 rounded-2xl bg-white flex items-center justify-center text-2xl shadow-sm">
                    {bot.icon}
                  </div>
                </div>
                <div class="flex-1">
                  <div class="flex flex-wrap items-center gap-3 mb-2">
                    <h3 class="text-xl font-bold text-gray-900">{bot.name}</h3>
                    <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${bot.badge}`}>{bot.servers}</span>
                  </div>
                  <p class="text-gray-600 mb-4 leading-relaxed">{bot.description}</p>
                  <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1.5">
                    {bot.features.map(f => (
                      <li class="flex items-center gap-2 text-sm text-gray-700">
                        <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        {f}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Music bots -->
      <div>
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-purple-50 text-purple-700 rounded-full text-sm font-semibold mb-4">
            🎵 Music
          </div>
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3">The 4 best music bots</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">From multi-channel playback to Lavalink-powered high-fidelity audio. Two of these run on our own Lavalink nodes for the best possible sound quality.</p>
        </div>
        <div class="space-y-4">
          {musicBots.map(bot => (
            <div class={`rounded-2xl border p-6 sm:p-8 ${bot.bg} ${bot.border}`}>
              <div class="flex flex-col sm:flex-row sm:items-start gap-6">
                <div class="flex-shrink-0">
                  <div class="w-14 h-14 rounded-2xl bg-white flex items-center justify-center text-2xl shadow-sm">
                    {bot.icon}
                  </div>
                </div>
                <div class="flex-1">
                  <div class="flex flex-wrap items-center gap-3 mb-2">
                    <h3 class="text-xl font-bold text-gray-900">{bot.name}</h3>
                    <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${bot.badge}`}>{bot.servers}</span>
                    {bot.lavalink && (
                      <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-violet-100 text-violet-700 flex items-center gap-1">
                        ⚡ Lavalink-powered
                      </span>
                    )}
                  </div>
                  <p class="text-gray-600 mb-4 leading-relaxed">{bot.description}</p>
                  <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1.5">
                    {bot.features.map(f => (
                      <li class="flex items-center gap-2 text-sm text-gray-700">
                        <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        {f}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Lavalink callout -->
  <section class="py-12 bg-white border-y border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl p-8 flex flex-col sm:flex-row items-center gap-6 text-white" style="background: linear-gradient(135deg, #7C3AED 0%, #DB2777 100%)">
        <div class="text-5xl">⚡</div>
        <div class="flex-1">
          <h3 class="text-xl font-bold mb-1">FredBoat & Uzox run on our own Lavalink nodes</h3>
          <p class="text-purple-100 text-sm">Our UK-based Lavalink infrastructure is what makes these music bots sound so good. If you run your own music bot and need Lavalink hosting separately, we offer that too.</p>
        </div>
        <a
          href="/lavalink"
          class="flex-shrink-0 px-6 py-3 bg-white text-purple-700 font-bold rounded-xl hover:bg-purple-50 transition-colors whitespace-nowrap"
        >
          Lavalink Plans →
        </a>
      </div>
    </div>
  </section>

  <div id="pricing">
    <PricingTable
      client:load
      tiers={tiers}
      title="Simple, Honest Pricing"
      subtitle="One subscription covers your bots. No per-bot fees, no artificial limits. Annual billing saves you 2 months."
    />
  </div>

  <Accordion
    client:load
    title="Frequently Asked Questions"
    items={faqs}
  />

  <CTABanner
    title="9 bots. One subscription. Zero maintenance."
    subtitle="Community, moderation, and music — all running on our infrastructure."
    primaryHref="/contact?service=discord-bots"
    primaryLabel="Get Started"
    secondaryHref="#pricing"
    secondaryLabel="Compare Plans"
  />
</Layout>
