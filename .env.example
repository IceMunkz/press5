# ── Contact form ────────────────────────────────────────────────────────────────
# Get your free Resend API key at https://resend.com (3,000 emails/month free)
RESEND_API_KEY=re_your_key_here

# The email address that receives contact form submissions
CONTACT_EMAIL=you@press5.xyz


# ── TeamSpeak server ─────────────────────────────────────────────────────────────
#
# VOICE PORT (port clients connect to for audio — this is what you already have)
# Default TS3 voice port is 9987 (UDP). This controls the ts3server:// connect links.
TS_VOICE_PORT=9987

# QUERY HOST — the hostname/IP the server-side API uses to query live stats
TS_QUERY_HOST=press5.xyz

# VIRTUAL SERVER ID (almost always 1 for single-server setups)
TS_SERVER_ID=1

# ── Option A: Raw ServerQuery (TCP port 10011) ────────────────────────────────
# This is the classic TS3 admin interface. To use it, port 10011 must be open
# in your firewall for incoming TCP connections FROM your web server's IP.
# You can whitelist just your web server's IP rather than opening it to the world.
TS_QUERY_PORT=10011
TS_QUERY_USER=serveradmin
TS_QUERY_PASS=your_serverquery_password_here

# ── Option B: Web Query API (TCP port 10080) ─────────────────────────────────
# Available on TS3 server 3.13.0+. Uses HTTP instead of raw TCP — easier to
# firewall safely. Enable in your ts3server.ini:
#   query_protocols=raw,http
# Then open port 10080 TCP. Same credentials as Option A.
TS_WEB_QUERY_PORT=10080
# (Uses TS_QUERY_USER and TS_QUERY_PASS from Option A above)

# If NEITHER port is accessible from your web server, the widget still shows
# the server address and connect button — it just won't display live user counts.
