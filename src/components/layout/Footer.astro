---
const year = new Date().getFullYear();
---

<footer class="bg-gray-950 text-gray-400">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="text-xl font-bold text-white block mb-3">Press5.xyz</a>
        <p class="text-sm leading-relaxed mb-4">
          UK-based hosting since 2004. 20+ years of experience delivering fast, reliable web hosting, game servers, TeamSpeak, Discord bots, and Lavalink.
        </p>
        <div class="flex items-center gap-2">
          <span class="inline-block w-2 h-2 rounded-full bg-green-400 animate-pulse-slow"></span>
          <span class="text-xs text-green-400 font-medium">All systems operational</span>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Services</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/web-hosting" class="hover:text-white transition-colors">Web Hosting</a></li>
          <li><a href="/game-servers" class="hover:text-white transition-colors">Game Servers</a></li>
          <li><a href="/teamspeak" class="hover:text-white transition-colors">TeamSpeak Hosting</a></li>
          <li><a href="/discord-bots" class="hover:text-white transition-colors">Managed Discord Bots</a></li>
          <li><a href="/lavalink" class="hover:text-white transition-colors">Lavalink Hosting</a></li>
          <li><a href="/status" class="hover:text-white transition-colors">Server Status</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Company</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/contact" class="hover:text-white transition-colors">Contact Us</a></li>
          <li><a href="/legal/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/legal/terms-of-service" class="hover:text-white transition-colors">Terms of Service</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Connect</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="ts3server://press5.xyz"
              class="hover:text-white transition-colors flex items-center gap-2"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20 13C20 17.4 16.4 21 12 21C7.6 21 4 17.4 4 13C4 8.6 7.6 5 12 5C16.4 5 20 8.6 20 13ZM12 3C6.5 3 2 7.5 2 13C2 18.5 6.5 23 12 23C17.5 23 22 18.5 22 13C22 7.5 17.5 3 12 3ZM12 11C13.1 11 14 11.9 14 13C14 14.1 13.1 15 12 15C10.9 15 10 14.1 10 13C10 11.9 10.9 11 12 11Z"/>
              </svg>
              Join TeamSpeak
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class="hover:text-white transition-colors flex items-center gap-2"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Email Support
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
      <p>© {year} Press5.xyz. All rights reserved. UK-based hosting since 2004.</p>
      <div class="flex items-center gap-4">
        <a href="/legal/privacy-policy" class="hover:text-white transition-colors">Privacy</a>
        <a href="/legal/terms-of-service" class="hover:text-white transition-colors">Terms</a>
        <a href="/status" class="hover:text-white transition-colors">Status</a>
      </div>
    </div>
  </div>
</footer>
